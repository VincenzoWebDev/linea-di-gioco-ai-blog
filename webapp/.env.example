APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=linea_di_gioco
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

AI_NEWS_AI_ENABLED=true
AI_NEWS_AUTO_PUBLISH=true
AI_NEWS_AI_PROVIDER=ollama
AI_NEWS_AI_BASE_URL=http://127.0.0.1:11434
AI_NEWS_AI_API_KEY=
AI_NEWS_AI_MODEL=gpt-oss:120b-cloud
AI_NEWS_AI_TEMPERATURE=0.4
AI_NEWS_AI_TIMEOUT_SECONDS=90
AI_NEWS_MIN_QUALITY_SCORE=60
AI_NEWS_SCOPE_STORE_REJECTED=true
AI_NEWS_DEDUP_ENABLED=true
AI_NEWS_DEDUP_SIMILARITY_THRESHOLD=0.72
AI_NEWS_DEDUP_LOOKBACK_DAYS=14
AI_NEWS_DEDUP_CANDIDATE_LIMIT=80
AI_NEWS_CREWAI_ENABLED=true
AI_NEWS_CREWAI_BASE_URL=http://127.0.0.1:8001
AI_NEWS_CREWAI_ENDPOINT=/process
AI_NEWS_CREWAI_TIMEOUT_SECONDS=120
AI_NEWS_CREWAI_API_KEY=
AI_NEWS_INGEST_TOKEN=change-me-ingest-token
AI_NEWS_QUEUE_INGEST=news-ingest
AI_NEWS_QUEUE_INGEST_RECEIVE=news-ingest
AI_NEWS_QUEUE_EXTRACT=news-extract
AI_NEWS_QUEUE_SANITIZE=news-sanitize
AI_NEWS_QUEUE_PUBLISH=news-publish
AI_NEWS_QUEUE_IMAGES=news-images
AI_NEWS_IMAGES_ENABLED=true
AI_NEWS_IMAGES_PROVIDER=gemini
AI_NEWS_IMAGES_BASE_URL=https://generativelanguage.googleapis.com
AI_NEWS_IMAGES_API_KEY=your-gemini-api-key
AI_NEWS_IMAGES_MODEL=gemini-2.5-flash-image
AI_NEWS_IMAGES_TIMEOUT_SECONDS=60
AI_NEWS_IMAGES_RETRY_ATTEMPTS=1
AI_NEWS_IMAGES_RETRY_SLEEP_MS=4000
AI_NEWS_IMAGES_STYLE="editoriale realistico, geopolitica, nessun logo o testo leggibile"
