CREWAI_MODEL=ollama/gpt-oss:120b-cloud
OLLAMA_BASE_URL=http://127.0.0.1:11434
CREWAI_REQUIRE_JSON=true
API_BIND_HOST=127.0.0.1
API_BIND_PORT=8001
AI_SCOUT_TIMEOUT_SECONDS=15

# Optional override JSON array: official editorial RSS sources only
AI_NEWS_SOURCES_JSON='[{"name":"BBC World","url":"https://feeds.bbci.co.uk/news/world/rss.xml"},{"name":"BBC Middle East","url":"https://feeds.bbci.co.uk/news/world/middle_east/rss.xml"},{"name":"Guardian World","url":"https://www.theguardian.com/world/rss"},{"name":"Guardian Politics","url":"https://www.theguardian.com/politics/rss"},{"name":"Al Jazeera","url":"https://www.aljazeera.com/xml/rss/all.xml"}]'

# Laravel ingest endpoint
LARAVEL_INGEST_URL=http://127.0.0.1:8000/api/ai-news/ingest
LARAVEL_INGEST_TOKEN=change-me-ingest-token
LARAVEL_INGEST_TIMEOUT_SECONDS=25
